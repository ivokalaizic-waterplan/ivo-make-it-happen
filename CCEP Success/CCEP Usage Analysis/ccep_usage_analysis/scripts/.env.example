# =============================================================================
# CCEP Usage Analysis - Environment Variables
# =============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- FullStory API ---
# Used to fetch session replay data and user segments.
# Obtain from FullStory Settings > API Keys.
# Auth method: HTTP Basic (pass as username, no password).
FS_API_KEY=

# --- Waterplan Back Office ---
# Admin JWT token for querying the Waterplan Back Office API.
# Used to retrieve CCEP's access control config, feature flags, and module settings.
# Obtain from: Login to Back Office, copy JWT from browser dev tools or use admin credentials.
WATERPLAN_BACKOFFICE_TOKEN=

# --- Waterplan Client API ---
# Standard user JWT for querying the V3 client API.
# Used to retrieve company data, sites, targets, and activity logs.
# Obtain from: Login to Waterplan app, copy JWT from browser dev tools.
WATERPLAN_API_TOKEN=

# --- Waterplan API Base URL ---
# The base URL of the Waterplan API.
# Production: https://api.waterplan.com
# Staging: https://api-staging.waterplan.com
WATERPLAN_API_BASE_URL=https://api.waterplan.com

# --- Anthropic API (optional) ---
# Used by session-explorer for AI-powered session classification.
ANTHROPIC_API_KEY=

# --- CCEP Company Identifier ---
# The slug used to identify CCEP in the Waterplan platform.
CCEP_COMPANY_ID=coca-cola-euro-pacific

# --- Database Access (optional, for direct queries) ---
# Only needed if running direct SQL queries against the audit database.
# Requires VPN/Basti tunnel to RDS.
AUDIT_DB_HOST=
AUDIT_DB_PORT=5432
AUDIT_DB_NAME=audit-db
AUDIT_DB_USER=
AUDIT_DB_PASSWORD=
