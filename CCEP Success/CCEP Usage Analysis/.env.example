# Waterplan CCEP Usage Analysis - Environment Variables
# Copy this file to .env and fill in the values.

# Required: Back Office admin JWT token for API authentication.
# Obtain from the Waterplan Back Office login or from an admin session.
WATERPLAN_BACKOFFICE_TOKEN=

# Optional: API base URL. Defaults to https://api.waterplan.com if not set.
# For staging, use the staging API URL instead.
WATERPLAN_API_BASE_URL=https://api.waterplan.com
